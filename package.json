{
  "name": "@rrulenet/events",
  "version": "0.1.8",
  "description": "Event-set projection layer for contextual scheduling with @rrulenet/recurrence.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rrulenet/events.git"
  },
  "homepage": "https://github.com/rrulenet/events#readme",
  "bugs": {
    "url": "https://github.com/rrulenet/events/issues"
  },
  "keywords": [
    "rrule",
    "recurrence",
    "events",
    "scheduling",
    "temporal",
    "calendar"
  ],
  "files": [
    "assets",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "npm exec --package=tsdown --package=typescript -- tsdown --config tsdown.config.ts",
    "test": "npm run build && node --test test/**/*.test.js",
    "coverage": "npm run build && node --experimental-test-coverage --test-coverage-include=dist/**/*.mjs --test test/**/*.test.js",
    "coverage:badge": "node scripts/write-coverage-badge.mjs coverage-output.txt badges/coverage.json",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@rrulenet/recurrence": "^0.1.8",
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.13",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
